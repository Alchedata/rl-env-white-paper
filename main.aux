\@writefile{toc}{\contentsline {section}{\numberline {9}The Sim-to-Real Gap in User Simulation}{36}{section.9}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces The reality gap between simulated training environments and real-world deployment. Simulated environments (USI $\sim $76) exhibit excessive cooperativeness and uniformly positive feedback, while real-world interactions (USI $\sim $93) involve partial information and nuanced judgment. This gap comprises behavioral differences (information front-loading) and evaluative differences (scoring simplification).}}{36}{figure.caption.21}\protected@file@percent }
\newlabel{fig:sim2real}{{7}{36}{The reality gap between simulated training environments and real-world deployment. Simulated environments (USI $\sim $76) exhibit excessive cooperativeness and uniformly positive feedback, while real-world interactions (USI $\sim $93) involve partial information and nuanced judgment. This gap comprises behavioral differences (information front-loading) and evaluative differences (scoring simplification)}{figure.caption.21}{}}

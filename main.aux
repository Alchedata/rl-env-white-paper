\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces A taxonomy of the five core agentic capabilities required for autonomous operation: Planning (decomposition, goal setting, replanning), Tool Use (API calling, code execution), Memory (short-term, long-term, episodic), Self-Improvement (learning from feedback, error recognition), and Reasoning (chain-of-thought, verification).}}{11}{figure.caption.6}\protected@file@percent }
\newlabel{fig:taxonomy}{{3}{11}{A taxonomy of the five core agentic capabilities required for autonomous operation: Planning (decomposition, goal setting, replanning), Tool Use (API calling, code execution), Memory (short-term, long-term, episodic), Self-Improvement (learning from feedback, error recognition), and Reasoning (chain-of-thought, verification)}{figure.caption.6}{}}
